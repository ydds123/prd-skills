        "tab": {
          "label": "Tab",
          "items": [
            { "id": "F27", "text": "默认：默认选中哪个Tab，Tab图没加载出来的默认显示", "level": "blocking", "applies": "has_tab" },
            { "id": "F28", "text": "切换：是否支持滑动切换", "level": "advisory", "applies": "has_tab" },
            { "id": "F29", "text": "记忆：离开后再次进入是否记住上次浏览Tab", "level": "advisory", "applies": "has_tab" },
